{
  "name": "@corivo/cli",
  "version": "0.11.0",
  "description": "你的硅基同事 — 它只为你活着",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "corivo": "bin/corivo.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "package": "npm run build && pkg . --targets node18-macos-arm64,node18-macos-x64,node18-linux-x64 --output ../../binaries/corivo"
  },
  "keywords": [
    "memory",
    "ai",
    "knowledge-management",
    "cli"
  ],
  "author": "Corivo Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "pkg": "^5.8.1",
    "prebuildify": "^6.0.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
