{
  "name": "corivo",
  "version": "0.12.6",
  "description": "你的硅基同事 — 它只为你活着",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "corivo": "bin/corivo.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "build:prod": "NODE_ENV=production CORIVO_ENV=production tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:prod",
    "package": "npm run build:prod && pkg . --targets node18-macos-arm64,node18-macos-x64,node18-linux-x64 --output ../../binaries/corivo"
  },
  "pkg": {
    "assets": [
      "node_modules/@corivo-ai/codex/**/*",
      "node_modules/@corivo-ai/claude-code/**/*",
      "node_modules/@corivo-ai/cursor/**/*",
      "node_modules/@corivo-ai/opencode/assets/**/*"
    ]
  },
  "keywords": [
    "memory",
    "ai",
    "knowledge-management",
    "cli"
  ],
  "author": "Corivo Team",
  "license": "MIT",
  "dependencies": {
    "@corivo-ai/claude-code": "workspace:*",
    "@corivo-ai/codex": "workspace:*",
    "@corivo-ai/cursor": "workspace:*",
    "@corivo-ai/opencode": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "consola": "^3.4.2",
    "ink": "^5.2.1",
    "ink-table": "^3.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "pkg": "^5.8.1",
    "prebuildify": "^6.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
