{
  "description": "Corivo Hooks for Cursor active memory",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CURSOR_PLUGIN_ROOT}/hooks/scripts/session-carry-over.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CURSOR_PLUGIN_ROOT}/hooks/scripts/prompt-recall.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CURSOR_PLUGIN_ROOT}/hooks/scripts/stop-review.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
